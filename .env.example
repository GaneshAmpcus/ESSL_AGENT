# Previous month overlap window in days (handles late device syncs)
MONTH_OVERLAP_DAYS=90

# ── Local state ──────────────────────────────────────────────
STATE_DB_PATH=agent_state.db
LOG_DIR=logs
LOG_LEVEL=INFO
