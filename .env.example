# ── ESSL SQL Server ──────────────────────────────────────────
ESSL_SERVER=localhost
ESSL_PORT=1433
ESSL_DATABASE=ESSL
ESSL_DRIVER=ODBC Driver 17 for SQL Server

# ── HRMS API ─────────────────────────────────────────────────
HRMS_API_BASE_URL=http://127.0.0.1:8000/api/v1/attendance/
